    "\n",
    "# DATAFRAME CONVERTER UTILITY\n",
    "\n",
    "def records_to_dataframe(records):\n",
    "\n",
    "    if len(records) == 0:\n",
    "        raise Exception(\n",
    "            \"No records found to convert\"\n",
    "        )\n",
    "        \n",
    "    df = spark.createDataFrame(records)\n",
    "    return df"
   ]
