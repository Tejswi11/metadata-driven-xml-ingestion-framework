   "source": [
    "# FILE PROCESS CHECK\n",
    "\n",
    "\n",
    "def is_file_processed(\n",
    "    file_name,\n",
    "    audit_table\n",
    "):\n",
    "\n",
    "    count = spark.sql(f\"\"\"\n",
    "    SELECT COUNT(*)\n",
    "    FROM {audit_table}\n",
    "    WHERE file_name = '{file_name}'\n",
    "    AND status = 'SUCCESS'\n",
    "    \"\"\").collect()[0][0]\n",
    "\n",
    "    return count > 0"
   ]
  }
 ],
