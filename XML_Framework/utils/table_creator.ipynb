   "source": [
    "# TABLE CREATOR UTILITY\n",
    "\n",
    "def create_table(ddl):\n",
    "\n",
    "    spark.sql(ddl)\n",
    "\n",
    "def table_exists(\n",
    "    catalog,\n",
    "    schema,\n",
    "    table_name\n",
    "):\n",
    "\n",
    "    try:\n",
    "\n",
    "        spark.table(\n",
    "            f\"{catalog}.{schema}.{table_name}\"\n",
    "        )\n",
    "\n",
    "        return True\n",
    "\n",
    "    except:\n",
    "\n",
    "        return False"
   ]
  }
